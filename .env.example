# =========================================================================
# CONFIGURAÇÃO DE VARIÁVEIS DE AMBIENTE (.env)
# Crie um arquivo chamado '.env' no mesmo diretório deste exemplo e preencha 
# as variáveis abaixo com suas credenciais.
# =========================================================================

# --- Banco de Dados PostgreSQL (Local Docker ou VPS) ---
DB_USER=postgres
DB_PASSWORD=postgres_secure_pass
DB_NAME=gestao_folha

# --- Segurança do Sistema (Backend JWT) ---
# Altere para uma chave longa e complexa em produção
JWT_SECRET=sgfs_premium_secret_2026

# --- Domínio de Produção ---
# Substitua pelo seu subdomínio ou domínio configurado no Nginx do seu VPS
DOMAIN=localhost
